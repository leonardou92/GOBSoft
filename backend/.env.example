# ==========================================================
# Gestión de Operaciones Bancarias - Variables de entorno (ejemplo)
# Copia este archivo como .env y ajusta valores reales.
# ==========================================================

# ----------------------------------------------------------
# Entorno y servidor
# ----------------------------------------------------------
# development | production
NODE_ENV=development

# Puerto HTTP del backend
PORT=3000

# CORS permitido (solo se usa en producción).
# Múltiples orígenes separados por coma.
# Ejemplo:
# CORS_ORIGIN=https://app.tudominio.com,https://admin.tudominio.com
CORS_ORIGIN=

# ----------------------------------------------------------
# Seguridad JWT
# ----------------------------------------------------------
# Secreto para firmar/verificar JWT.
# En producción usa un valor largo, aleatorio y privado.
JWT_SECRET=REEMPLAZAR_CON_SECRETO_SEGURO

# Duración del token (ej: 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# Clave opcional para cifrar secretos 2FA.
# Si se omite, el sistema usa JWT_SECRET como fallback.
TWO_FACTOR_ENCRYPTION_KEY=

# ----------------------------------------------------------
# Base de datos (Prisma / MySQL)
# ----------------------------------------------------------
DATABASE_URL="mysql://user:password@localhost:3306/gestion_operaciones_bancarias"

# ----------------------------------------------------------
# Jobs de sincronización
# ----------------------------------------------------------
# Expresión CRON para sincronizador de estado de cuenta.
# Formato: MIN HORA DIA MES DIA_SEMANA
# Ejemplos:
# */10 * * * *  -> cada 10 minutos
# 0 * * * *     -> cada hora
# 0 3 * * *     -> todos los días a las 03:00
STATEMENT_SYNC_CRON=*/10 * * * *

# Fecha de inicio para la sincronización histórica inicial.
# Formato: YYYY-MM-DD
# Requerida por el arranque actual del backend.
INITIAL_SYNC_START_DATE=2025-10-01